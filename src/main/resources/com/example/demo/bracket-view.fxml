<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.demo.BracketController">

    <!-- Левая панель — список команд -->
    <left>
        <VBox fx:id="teamPool" spacing="12" style="-fx-padding: 20; -fx-background-color: #f0f4f8; -fx-border-color: #ccd;" prefWidth="260">
            <Label text="Команды " style="-fx-font-size: 18; -fx-font-weight: bold; -fx-padding: 0 0 10 0;" />

        </VBox>
    </left>

    <!-- Центр: сетка + кнопки снизу -->
    <center>
        <VBox spacing="0" style="-fx-padding: 0;">
            <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS"
                        hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
                        style="-fx-background: transparent;">
                <AnchorPane fx:id="bracketPane" minWidth="1650" minHeight="1450"
                            style="-fx-background-color: #f9fbfd;" />
            </ScrollPane>

            <!-- Кнопки внизу -->
            <HBox alignment="CENTER" spacing="40" style="-fx-padding: 12; -fx-background-color: #f0f4f8; -fx-border-color: #d0d8e0; -fx-border-width: 1 0 0 0;">
                <Button text="Сброс сетки" onAction="#resetBracket" prefWidth="180" prefHeight="42" />
                <Button text="Случайный посев" onAction="#randomSeed" prefWidth="180" prefHeight="42" />
            </HBox>
        </VBox>
    </center>

    <!-- Правая панель — таблица результатов -->
    <right>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #fffaf0; -fx-border-color: #eed;" prefWidth="280">
            <Label text="Таблица продвижения" style="-fx-font-size: 17; -fx-font-weight: bold;" />
            <GridPane fx:id="resultsGrid" hgap="12" vgap="8" style="-fx-padding: 10;">
                <!-- заполняется динамически -->
            </GridPane>
        </VBox>
    </right>

</BorderPane>